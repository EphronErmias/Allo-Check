# Backend base URL (no trailing slash)
VITE_API_URL=http://localhost:4000

# Optional: public URL used when copying share links (no trailing slash). Defaults to current origin.
# VITE_APP_ORIGIN=https://your-production-domain.com

# Optional: full URL to a hosted banner image, or leave unset to use /partners-banner.svg
# VITE_PARTNERS_BANNER_URL=https://example.com/banner.jpg

# “Buy original phones from Allo” link when lookup is Not Registered / Unknown
# VITE_ALLO_SHOP_URL=https://www.example.com/phones
