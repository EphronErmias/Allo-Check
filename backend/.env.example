PORT=4000
# Use Supabase pooler URL (port 6543) on Railway to avoid IPv6 reachability issues.
DATABASE_URL=postgresql://postgres.example:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
CORS_ORIGIN=*

# Optional: shared lookup links expire after this many days (default 30).
# SHARE_TTL_DAYS=30
